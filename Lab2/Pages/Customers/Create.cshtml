@page
@model CinemaApp.Pages.Customers.CreateModel
@{ViewData["Title"] = "Новий клієнт";}

<div class="page-header">
    <div class="page-title">НОВИЙ КЛІЄНТ</div>
    <a href="/Customers" class="btn btn-secondary">← Назад</a>
</div>
<div class="card" style="max-width:600px">
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
    <form method="post">
        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Customer.FirstName" class="form-label"></label>
                <input asp-for="Customer.FirstName" class="form-control" placeholder="Ім'я" />
                <span asp-validation-for="Customer.FirstName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Customer.LastName" class="form-label"></label>
                <input asp-for="Customer.LastName" class="form-control" placeholder="Прізвище" />
                <span asp-validation-for="Customer.LastName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Customer.Phone" class="form-label"></label>
                <input asp-for="Customer.Phone" class="form-control" placeholder="+380501234567" />
                <span asp-validation-for="Customer.Phone" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Customer.Email" class="form-label"></label>
                <input asp-for="Customer.Email" class="form-control" type="email" placeholder="email@example.com" />
                <span asp-validation-for="Customer.Email" class="text-danger"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">💾 Зберегти</button>
            <a href="/Customers" class="btn btn-secondary">Скасувати</a>
        </div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
