@page "{id:int}"
@model CinemaApp.Pages.Tickets.DeleteModel
@{ViewData["Title"] = "Видалити квиток";}

<div class="page-header"><div class="page-title">ВИДАЛИТИ КВИТОК</div></div>
<div class="card" style="max-width:500px">
    <div class="alert alert-danger">⚠️ Видалити квиток #@Model.Ticket.Ticket_ID на фільм <strong>«@Model.Ticket.Screening?.Film?.Title»</strong>?</div>
    <div class="detail-item"><div class="detail-label">Клієнт</div><div class="detail-value">@Model.Ticket.Customer?.FirstName @Model.Ticket.Customer?.LastName</div></div>
    <div class="detail-item"><div class="detail-label">Сеанс</div><div class="detail-value">@Model.Ticket.Screening?.StartTime.ToString("dd.MM.yyyy HH:mm")</div></div>
    <div class="detail-item"><div class="detail-label">Кількість</div><div class="detail-value">@Model.Ticket.Quantity</div></div>
    <form method="post" asp-route-id="@Model.Ticket.Ticket_ID">
        <div class="form-actions">
            <button type="submit" class="btn btn-danger">🗑 Видалити</button>
            <a href="/Tickets" class="btn btn-secondary">Скасувати</a>
        </div>
    </form>
</div>
