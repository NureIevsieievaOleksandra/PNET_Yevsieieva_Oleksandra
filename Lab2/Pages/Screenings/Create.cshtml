@page
@model CinemaApp.Pages.Screenings.CreateModel
@{ViewData["Title"] = "Новий сеанс";}

<div class="page-header">
    <div class="page-title">НОВИЙ СЕАНС</div>
    <a href="/Screenings" class="btn btn-secondary">← Назад</a>
</div>
<div class="card" style="max-width:600px">
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
    <form method="post">
        <div class="form-group">
            <label asp-for="Screening.Film_ID" class="form-label"></label>
            <select asp-for="Screening.Film_ID" asp-items="Model.Films" class="form-control">
                <option value="">— Оберіть фільм —</option>
            </select>
            <span asp-validation-for="Screening.Film_ID" class="text-danger"></span>
        </div>
        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Screening.Hall" class="form-label"></label>
                <input asp-for="Screening.Hall" class="form-control" placeholder="Зал 1" />
                <span asp-validation-for="Screening.Hall" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Screening.TotalSeats" class="form-label"></label>
                <input asp-for="Screening.TotalSeats" class="form-control" type="number" />
                <span asp-validation-for="Screening.TotalSeats" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Screening.StartTime" class="form-label"></label>
                <input asp-for="Screening.StartTime" class="form-control" type="datetime-local" />
                <span asp-validation-for="Screening.StartTime" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Screening.TicketPrice" class="form-label"></label>
                <input asp-for="Screening.TicketPrice" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Screening.TicketPrice" class="text-danger"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Зберегти</button>
            <a href="/Screenings" class="btn btn-secondary">Скасувати</a>
        </div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
